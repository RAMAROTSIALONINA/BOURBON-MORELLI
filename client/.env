# Désactiver les warnings WebSocket et Fast Refresh
GENERATE_SOURCEMAP=false
FAST_REFRESH=false

# Désactiver complètement WebSocket
DISABLE_ESLINT_PLUGIN=true
TSC_COMPILE_ON_ERROR=true
ELECTRONMONITOR_RESTART=false
CHOKIDAR_USEPOLLING=true
WDS_SOCKET_PORT=0
WDS_SOCKET_HOST=localhost
WDS_SOCKET_PATH=false
WDS_SOCKET_SERVER=false
WEBPACK_DEV_SERVER_WEB_SOCKET_SERVER=false
SOCKET=false
WS=false
