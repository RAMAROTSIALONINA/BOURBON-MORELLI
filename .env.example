# Configuration de la base de données
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=votre_mot_de_passe
DB_NAME=bourbon_morelli

# Configuration du serveur
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=votre_jwt_secret_tres_long_et_securise
JWT_EXPIRES_IN=7d

# Configuration Stripe
STRIPE_PUBLIC_KEY=pk_test_votre_cle_publique_stripe
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret

# Configuration PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=votre_client_id_paypal
PAYPAL_CLIENT_SECRET=votre_client_secret_paypal

# Configuration Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_email

# Configuration Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# URL du frontend
FRONTEND_URL=http://localhost:3000

# Configuration des devises
DEFAULT_CURRENCY=EUR
SUPPORTED_CURRENCIES=EUR,USD,MGA

# Taux de change (peuvent être mis à jour automatiquement)
EUR_TO_USD=1.08
EUR_TO_MGA=4900

# Configuration Docker
DB_ROOT_PASSWORD=rootpassword
DB_USER=bourbon_user
DB_PASSWORD=bourbon_password
